{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://assumption-toolbox.local/schemas/strategy-rules.schema.json",
  "title": "Strategy Rules",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "selectionPipeline", "rules"],
  "properties": {
    "version": { "type": "string" },
    "selectionPipeline": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "rules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "priority", "when", "then"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
          "priority": { "type": "integer", "minimum": 1 },
          "when": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "phaseIn": {
                "type": "array",
                "items": {
                  "type": "string",
                  "enum": [
                    "Understand Problem Space & Market",
                    "Test Value Proposition",
                    "Early Product",
                    "Mature Product"
                  ]
                }
              },
              "assumptionTypeIn": {
                "type": "array",
                "items": {
                  "type": "string",
                  "enum": ["desirability", "feasibility", "viability", "usability", "ethics"]
                }
              },
              "riskLevelIn": {
                "type": "array",
                "items": { "type": "string", "enum": ["low", "medium", "high"] }
              },
              "timeBudgetInWeeksMax": { "type": "integer", "minimum": 1 },
              "requiresStatisticalSignal": { "type": "boolean" },
              "hasExistingArtifact": { "type": "boolean" }
            }
          },
          "then": {
            "type": "object",
            "additionalProperties": false,
            "required": ["recommendCategories", "reasoning"],
            "properties": {
              "recommendCategories": {
                "type": "array",
                "items": {
                  "type": "string",
                  "enum": [
                    "Desktop Research",
                    "Self-Reportage",
                    "Watch User in Environment",
                    "Watch User with Artefact",
                    "Real-World Behaviour"
                  ]
                }
              },
              "preferMethodIds": {
                "type": "array",
                "items": { "type": "integer", "minimum": 1 }
              },
              "avoidMethodIds": {
                "type": "array",
                "items": { "type": "integer", "minimum": 1 }
              },
              "minimumMethodCount": { "type": "integer", "minimum": 1, "maximum": 10 },
              "mustIncludeQualThenQuant": { "type": "boolean" },
              "reasoning": { "type": "string" }
            }
          }
        }
      }
    }
  }
}
