{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://assumption-toolbox.local/schemas/test-strategy-response.schema.json",
  "title": "Test Strategy Response",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "strategySummary",
    "selectedMethods",
    "sequence",
    "riskMitigations",
    "evidenceQualityNotes"
  ],
  "properties": {
    "strategySummary": { "type": "string" },
    "selectedMethods": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["methodId", "whyIncluded", "expectedSignal"],
        "properties": {
          "methodId": { "type": "integer", "minimum": 1 },
          "whyIncluded": { "type": "string" },
          "expectedSignal": { "type": "string" },
          "category": {
            "type": "string",
            "enum": [
              "Desktop Research",
              "Self-Reportage",
              "Watch User in Environment",
              "Watch User with Artefact",
              "Real-World Behaviour"
            ]
          }
        }
      }
    },
    "sequence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["step", "goal", "methodIds"],
        "properties": {
          "step": { "type": "integer", "minimum": 1 },
          "goal": { "type": "string" },
          "methodIds": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "integer", "minimum": 1 }
          },
          "exitCriteria": { "type": "string" }
        }
      }
    },
    "riskMitigations": {
      "type": "array",
      "items": { "type": "string" }
    },
    "evidenceQualityNotes": {
      "type": "array",
      "items": { "type": "string" }
    },
    "followUpQuestions": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
